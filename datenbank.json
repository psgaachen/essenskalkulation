    "link": "https://www.kochenfuerviele.de/dessert-salate-rezepte/Fleischsalat.html",
    "category": "Salat",
    "rawCost": "normal/günstig",
    "baseP": 12,
    "ingredients": [
      {
        "qty": 750,
        "unit": "g",
        "name": "Fleischsalat"
      },
      {
        "qty": 750,
        "unit": "g",
