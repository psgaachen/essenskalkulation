  {
    "name": "Kartoffeln, Senfsoße und Eier",
    "link": "https://www.kochenfuerviele.de/mittagessen-kochen/Kartoffeln-Senfsosse-und-Eier.html",
    "category": "Mittagessen",
    "rawCost": "normal/überschaubar",
    "baseP": 12,
    "ingredients": [
      {
