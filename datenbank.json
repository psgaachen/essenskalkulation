      },
      {
        "qty": 600,
        "unit": "g",
        "name": "Quark"
      },
      {
        "qty": 150,
        "unit": "g",
        "name": "saure Sahne"
      },
      {
        "qty": 12,
        "unit": "große",
        "name": "vorgegarte Kartoffeln"
      },
      {
        "qty": 400,
        "unit": "g",
