  {
    "name": "Pilz-Brokkoli Salat",
    "link": "https://www.kochenfuerviele.de/dessert-salate-rezepte/Pilz-Brokkoli-Salat.html",
    "category": "Salate",
    "rawCost": "wenig/gering",
    "baseP": 10,
    "ingredients": [
      {
