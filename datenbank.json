    "link": "https://www.kochenfuerviele.de/mittagessen-kochen/Schweinsbraten-bayrische-Art.html",
    "category": "Fleischgerichte",
    "rawCost": "mittel/moderat",
    "baseP": 12,
    "ingredients": [
      {
        "qty": 3,
        "unit": "kg",
        "name": "Schweinefleisch mit Schwarte"
      },
      {
        "qty": 3,
        "unit": "große",
        "name": "Zwiebeln"
      },
      {
        "qty": 3,
