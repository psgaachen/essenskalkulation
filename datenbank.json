      },
      {
        "qty": 50,
        "unit": "g",
        "name": "frische Hefe"
      },
      {
        "qty": 1.5,
        "unit": "tl",
        "name": "Zimt"
      },
      {
        "qty": 7.5,
        "unit": "el",
        "name": "Zucker"
      },
      {
        "qty": 10,
