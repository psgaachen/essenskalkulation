    "link": "https://www.kochenfuerviele.de/mittagessen-kochen/Lende-ueberbacken-mit-Brie.html",
    "category": "Aufläufe",
    "rawCost": "simpel/moderat",
    "baseP": 12,
    "ingredients": [
      {
        "qty": 3,
        "unit": "kg",
        "name": "Schweine-Lende"
