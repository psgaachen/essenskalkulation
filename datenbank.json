      },
      {
        "qty": 0,
        "unit": "abgeriebene",
        "name": "feine Schale von 1 1/2 Zitronen"
      },
      {
        "qty": 0,
        "unit": "jeweils",
        "name": "3 kräftige Prisen Salz und Chilipulver"
      },
      {
        "qty": 0,
        "unit": "tl",
        "name": "Senf scharf"
      },
      {
        "qty": 0,
        "unit": "je",
        "name": "nach Geschmack noch Tabasco, schwarzer Pfeffer und Salz"
      }
