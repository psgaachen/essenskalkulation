        "unit": "hände",
        "name": "voll getrocknete Pilze"
      },
      {
        "qty": 6,
        "unit": "el",
        "name": "gesiebtes Mehl um die Suppe abzubinden"
      },
      {
        "qty": 3,
        "unit": "el",
