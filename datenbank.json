        "unit": "bund",
        "name": "Petersilie glatt"
      },
      {
        "qty": 3,
        "unit": "el",
        "name": "Butter"
      },
      {
        "qty": 0,
        "unit": "pfeffer",
        "name": "und Salz aus der Mühle"
