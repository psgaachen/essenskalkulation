        "name": "geräucherter, durchwachsener Speck"
      },
      {
        "qty": 500,
        "unit": "g",
        "name": "Goudakäse"
      },
      {
        "qty": 400,
        "unit": "g",
        "name": "Sahne"
      },
      {
