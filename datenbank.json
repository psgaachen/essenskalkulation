  {
    "name": "Partybrötchen",
    "link": "https://www.kochenfuerviele.de/abendessen-rezepte/Partybroetchen.html",
    "category": "Abendessen",
    "rawCost": "k.A.",
    "baseP": 12,
    "ingredients": [
