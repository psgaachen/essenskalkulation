        "qty": 800,
        "unit": "g",
        "name": "gemischtes Hackfleisch"
      },
      {
        "qty": 500,
        "unit": "g",
        "name": "Reis (parboiled, Vollkorn)"
      },
      {
        "qty": 1.2,
        "unit": "ml",
